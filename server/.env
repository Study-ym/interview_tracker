# 数据库配置（MySQL）
DB_HOST=localhost
DB_PORT=3306
DB_NAME=interview_tracker
DB_USER=localhost
DB_PASSWORD=

# JWT 密钥（随机生成，生产环境务必改）
JWT_SECRET=test-secret-key-for-development

# 腾讯云短信配置
TENCENT_SECRET_ID=
TENCENT_SECRET_KEY=
TENCENT_SMS_APP_ID=
TENCENT_SMS_SIGN=
TENCENT_SMS_TEMPLATE_ID=

# 服务端口
PORT=3000
NODE_ENV=development  # 重要：开发模式会打印验证码而不是真实发送
