# 数据库配置（MySQL）
DB_HOST=localhost
DB_PORT=3306
DB_NAME=interview_tracker
DB_USER=root
DB_PASSWORD=12345678

# JWT 密钥（随机生成，生产环境务必改）
JWT_SECRET=test-secret-key-for-development

# 短信服务选择：tencent 或 aliyun（默认腾讯云）
SMS_PROVIDER=aliyun

# 阿里云短信配置（若使用阿里云，设置 SMS_PROVIDER=aliyun）
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN=
ALIYUN_SMS_TEMPLATE_CODE=

# 服务端口
PORT=3000
NODE_ENV=development  # 重要：开发模式会打印验证码而不是真实发送
